// Portiert aus docs/reference/schema.prisma + REWRITE_PLAN (schematicPdfUrl).
// URLs: prisma.config.ts (Prisma ORM 7)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Enums
// ==========================================

/**
 * Lebenszyklus der AI-Generation für einen Result.
 * `idle`      — initial; noch nie gestartet.
 * `pending`   — atomar reserviert, Berechnung läuft.
 * `succeeded` — Berechnung + Empfehlungen persistiert.
 * `failed`    — Letzter Versuch fehlgeschlagen; Retry möglich (resettet auf `pending`).
 */
enum GenerationStatus {
  idle
  pending
  succeeded
  failed
}

/**
 * Schaltplan-Darstellung: Einsteiger vs. Profi (Roadmap; MVP nutzt professional).
 */
enum SchematicVariant {
  beginner
  professional
}

// ==========================================
// Result (Ergebnis)
// ==========================================
model Result {
  id       String @id @default(uuid())
  version  Int    @default(1)
  formData Json

  calculations    Json?
  recommendations Json?

  schematicData     Json?
  schematicImageUrl String?
  schematicPdfUrl   String?

  aiModel      String?
  inputTokens  Int?
  outputTokens Int?

  creditsUsed Int @default(0)

  // Idempotenter Generation-Lock. Atomarer Übergang `idle|failed → pending`
  // via `updateMany` verhindert doppelte AI-Kosten bei Parallelzugriff.
  generationStatus    GenerationStatus @default(idle)
  generationStartedAt DateTime?
  generationError     String?

  schematicVariant SchematicVariant @default(professional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  creditBalance   CreditBalance?
  creditUsages    CreditUsage[]
  creditPurchases CreditPurchase[]

  @@index([createdAt])
  @@index([generationStatus])
}

// ==========================================
// Product (Produkt)
// ==========================================
model Product {
  id           String   @id @default(uuid())
  name         String
  description  String?
  icon         String?
  imageUrl     String?
  affiliateUrl String?
  asin         String?
  price        Decimal? @db.Decimal(12, 2)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  specVersion Int    @default(1)
  specs       String @default("")

  powerW            Int?
  capacityAh        Int?
  voltageV          Int?
  batteryType       String?
  currentA          Int?
  crossSectionMm2   Float?
  solarWp           Int?
  supportedVoltages Json?
  maxDischargeA     Int?
  waveform          String?
  fuseType          String?

  filterValues Json?

  isActive Boolean @default(true)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([asin])
  @@index([categoryId])
  @@index([isActive])
  @@index([isActive, categoryId])
}

// ==========================================
// Category (Kategorie)
// ==========================================
model Category {
  id        String  @id @default(uuid())
  name      String
  slug      String  @unique
  icon      String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  filters  CategoryFilter[]
}

// ==========================================
// CategoryFilter (Filter-Definition pro Kategorie)
// ==========================================
model CategoryFilter {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name      String
  key       String
  type      String
  unit      String?
  options   String[] @default([])
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, key])
  @@index([categoryId])
}

// ==========================================
// CreditPurchase (Kauf)
// ==========================================
model CreditPurchase {
  id       String @id @default(uuid())
  resultId String
  result   Result @relation(fields: [resultId], references: [id], onDelete: Restrict)

  paypalOrderId String @unique
  paypalStatus  String

  packageType String
  credits     Int
  amount      Decimal @db.Decimal(12, 2)
  currency    String  @default("EUR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resultId])
}

// ==========================================
// CreditBalance (Guthaben pro Result)
// ==========================================
model CreditBalance {
  id       String @id @default(uuid())
  resultId String @unique
  result   Result @relation(fields: [resultId], references: [id], onDelete: Cascade)

  balance Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// CreditUsage (Verwendung)
// ==========================================
model CreditUsage {
  id       String @id @default(uuid())
  resultId String
  result   Result @relation(fields: [resultId], references: [id], onDelete: Cascade)

  amount Int
  action String

  createdAt DateTime @default(now())

  @@index([resultId])
}

// ==========================================
// PromptVersion (KI-Prompt-Versionen)
// ==========================================
model PromptVersion {
  id                 String @id @default(uuid())
  version            Int    @unique
  systemPrompt       String
  userPromptTemplate String

  isActive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, createdAt])
}

// ==========================================
// ConsumerCategory (Verbraucher-Kategorien im Wizard)
// ==========================================
model ConsumerCategory {
  id        String  @id @default(uuid())
  name      String
  slug      String  @unique
  icon      String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices ConsumerDevice[]
}

// ==========================================
// ConsumerDevice (Verbraucher-Geräte im Wizard)
// ==========================================
model ConsumerDevice {
  id      String  @id @default(uuid())
  name    String
  i18nKey String?
  icon    String?

  defaultPower       Int    @default(50)
  defaultVoltage     String @default("12V")
  defaultHoursPerDay Float  @default(2)
  stepHours          Float  @default(0.5)

  /// Durchschnittliche Leistung in % der Nominalleistung (`defaultPower`).
  /// Wird im Wizard/Algorithmus als Faktor für den Tagesverbrauch verwendet,
  /// während die volle Leistung für Wechselrichter-Peak-Dimensionierung gilt.
  /// `null` oder `100` ⇒ kein Rabatt.
  averageLoadPercent Int?

  showHoursField  Boolean @default(true)
  showFixedOption Boolean @default(false)
  isCooling       Boolean @default(false)

  keywords String[] @default([])

  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  categoryId String
  category   ConsumerCategory @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isActive])
}

// ==========================================
// System Settings (Globale Einstellungen)
// ==========================================
model SystemSetting {
  key   String @id
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Model Pricing (KI-Modell Preise)
// ==========================================
model ModelPricing {
  id          String  @id @default(uuid())
  modelId     String  @unique
  displayName String?
  provider    String

  inputPrice  Decimal @default(0) @db.Decimal(12, 6)
  outputPrice Decimal @default(0) @db.Decimal(12, 6)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Algorithm Settings (Berechnungsparameter)
// ==========================================
model AlgorithmSettings {
  id String @id @default("default")

  dodLifepo4 Float @default(0.95)
  dodAgm     Float @default(0.50)
  dodGel     Float @default(0.50)

  simultaneousLow      Float @default(0.30)
  simultaneousModerate Float @default(0.50)
  simultaneousHigh     Float @default(0.80)

  alternatorStandard   Float @default(30.0)
  alternatorEnhanced   Float @default(90.0)
  alternatorDriveHours Float @default(2.0)
  boosterEfficiency    Float @default(0.95)

  batterySafetyFactor Float @default(1.20)
  solarSafetyFactor   Float @default(1.10)

  standingDaysShort  Float @default(2.0)
  standingDaysMedium Float @default(5.0)
  standingDaysLong   Float @default(8.0)

  maxBackupDays Float @default(5.0)

  wpPerM2Rigid    Float @default(235.0)
  wpPerM2Flexible Float @default(180.0)

  cloudyYieldFactor           Float @default(0.30)
  cloudyYieldFactorSummer     Float @default(0.50)
  cloudyYieldFactorWinter     Float @default(0.20)
  recommendedSolarYieldFactor Float @default(1.20)
  solarSystemEfficiency       Float @default(0.85)
  maxPortableWp               Int   @default(400)

  roofUtilizationFactor     Float @default(0.80)
  roofOrientationFactor     Float @default(0.85)
  portableOrientationFactor Float @default(1.0)

  sunHoursSummer  Float @default(5.0)
  sunHoursAllYear Float @default(3.5)
  sunHoursWinter  Float @default(2.0)

  locationGermanyAlps    Float @default(0.8)
  locationSouthernEurope Float @default(1.2)
  locationScandinavia    Float @default(0.6)
  locationEastern        Float @default(0.9)
  locationVaries         Float @default(1.0)

  dutyCycleCompressor Float @default(0.35)
  dutyCycleAbsorber   Float @default(0.7)

  inverterClasses String @default("500,800,1000,1500,2000,2500,3000,5000")
  chargerClasses  String @default("10,20,30,50,60")

  chargerTimeHoursSlow   Float @default(12.0)
  chargerTimeHoursNormal Float @default(8.0)
  chargerTimeHoursFast   Float @default(5.0)

  chargerAbsorptionOverhead Float @default(0.15)

  solarControllerClasses String @default("10,20,30,40,50,60,80,100")
  cableSizes             String @default("6,10,16,25,35,50,70,95,120")

  voltageDropCritical Float @default(2.0)
  voltageDropNormal   Float @default(3.0)
  voltageDropSolar    Float @default(3.0)

  copperResistivity Float @default(0.0178)

  minPreselectionScore Int @default(30)

  productSelectionMode String @default("algorithm")
  reasonGenerationMode String @default("algorithm")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Brand (Marken-Präferenzen)
// ==========================================
model Brand {
  id   String @id @default(uuid())
  name String

  showInPreferences Boolean  @default(true)
  types             String[] @default([])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@unique([name])
  @@index([isActive, name])
}

// ==========================================
// BrandFilterCategory (Kategorien-Zuordnung für Wizard)
// ==========================================
model BrandFilterCategory {
  id            String   @id @default(uuid())
  key           String   @unique
  label         String
  categorySlugs String[]

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Algorithm test — gespeicherte Nutzer-Szenarien (Admin „Algorithmus testen“)
// ==========================================
model AlgorithmTestUserPreset {
  id          String  @id @default(uuid())
  name        String
  description String?
  /// Vollständiger Wizard-/Algorithmus-Input (`AlgorithmInput`), validiert beim Speichern.
  formData    Json
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}
