# PostgreSQL (Prisma ORM 7 — `prisma.config.ts`; Client mit `@prisma/adapter-pg` + `pg`)
# `prisma.config.ts` lädt nacheinander `.env` und `.env.local` (lokal überschreibbar).
#
# Neon: App nutzt gepoolte URL (Host enthält meist „-pooler.…“), Prisma CLI (migrate) die direct URL:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&uselibpqcompat=true"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&uselibpqcompat=true"
#
# Optional: `pg` Pool-Größe (Standard: 10, bei Neons Hosts oft 3 — siehe `src/lib/db/client.ts`):
# DATABASE_POOL_MAX=3
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/powersetup?schema=public"
# Beispiel Prisma Postgres (nur Verbindungsstring hier dokumentieren, echte Secrets in `.env.local`):
# `uselibpqcompat=true` vermeidet eine pg-Warnung zu künftigen sslmode-Semantiken (siehe `src/lib/db/client.ts`).
# DATABASE_URL="postgresql://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require&uselibpqcompat=true"
# Strikte TLS-Zertifikatsprüfung für den pg-Pool (optional; Standard: nicht gesetzt = weniger strikt):
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Cursor/VS Code Simple Browser bei lokalem `next start`: iframe erlauben (CSP / X-Frame-Options).
# ALLOW_EMBEDDED_PREVIEW=1

# Basic Auth für /admin/* und /api/admin/*
ADMIN_PASSWORD="change-me"
# Cursor Simple Browser: kein Basic-Auth-Dialog → weiße Seite. Nur bei `next dev` + explizit setzen:
# ADMIN_SKIP_BASIC_AUTH_IN_DEV=1
# Optional, Standard: admin
# ADMIN_USERNAME="admin"

# KI (Phase 4 — `src/lib/ai/client.ts`; Fallback Gemini → OpenAI)
# GEMINI_API_KEY=
# Oder: GOOGLE_GENERATIVE_AI_API_KEY=
# OPENAI_API_KEY=
# CI / ohne echte APIs:
# USE_MOCK_AI=true

# Schaltplan-KI: ohne echte APIs Mock-JSON (Tests / lokale UI ohne Gemini):
# USE_MOCK_SCHEMATIC=true

# Öffentliche Basis-URL (PayPal Return, Links)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayPal (Sandbox) — Credits kaufen (`/api/payments/*`)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# PDF (Puppeteer): Pfad zu Chrome/Chromium — lokal Windows/macOS zwingend, Linux/Vercel optional (@sparticuz/chromium)
# PUPPETEER_EXECUTABLE_PATH=

# Vercel Blob (Admin-Mediathek: PS-7; Uploads unter `admin/*`)
# Ohne Token liefert /api/admin/media/upload 503 und `/admin/media` zeigt einen Hinweis.
# BLOB_READ_WRITE_TOKEN=
